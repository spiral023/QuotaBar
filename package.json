{
  "name": "quotabar",
  "version": "0.1.0",
  "description": "QuotaBar for Windows - Electron tray app for AI coding quota usage",
  "main": "dist/main/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "npm run build && electron . --no-window --debug",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "package": "npm run build && electron-builder --win --publish never"
  },
  "keywords": [
    "electron",
    "tray",
    "codex",
    "claude"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "electron-log": "^5.2.4",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/pngjs": "^6.0.5",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "typescript": "^5.8.3",
    "vitest": "^1.6.1"
  }
}
